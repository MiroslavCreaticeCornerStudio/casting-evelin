---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = 'Стани звезден брокер в „Борба до ключ" 2 по NOVA | INclusive кастинг',
  description = 'Кастингът е отворен. Влез в света на INclusive, научи имотния бизнес отвътре и заеми мястото си до Евелин Апостолов. Кандидатствай сега за „Борба до ключ" 2 по NOVA.',
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://inclusive.example.com');
---

<!doctype html>
<html lang="bg">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="bg_BG" />
    <meta property="og:url" content={canonical} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Real fonts via Adobe Typekit: le-havre (display) + futura-pt (body) -->
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/fas0rfi.css" />
    <!-- Fallback fonts (Montserrat / Manrope) — keep full Cyrillic + extra weights if Typekit is slow/blocked -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap&subset=cyrillic,cyrillic-ext,latin"
      rel="stylesheet"
    />

    <!-- GSAP + ScrollTrigger via CDN for scroll animations -->
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js" is:inline></script>
  </head>
  <body>
    <a href="#main" class="sr-only">Към основното съдържание</a>
    <slot />

    <script is:inline>
      // Soft, professional scroll-reveal animations. Respects reduced-motion.
      window.addEventListener('load', () => {
        if (typeof gsap === 'undefined') return;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce) return;

        gsap.registerPlugin(ScrollTrigger);

        // Generic fade-up for elements tagged [data-reveal]
        gsap.utils.toArray('[data-reveal]').forEach((el) => {
          gsap.from(el, {
            opacity: 0,
            y: 40,
            duration: 1,
            ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 85%', once: true },
          });
        });

        // Staggered groups for elements tagged [data-reveal-group] > children
        gsap.utils.toArray('[data-reveal-group]').forEach((group) => {
          gsap.from(group.children, {
            opacity: 0,
            y: 40,
            duration: 0.9,
            ease: 'power2.out',
            stagger: 0.12,
            scrollTrigger: { trigger: group, start: 'top 85%', once: true },
          });
        });
      });
    </script>
  </body>
</html>
