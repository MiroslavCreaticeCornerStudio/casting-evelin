---
// Video section — Запознай се с Евелин. Figma node 2168:431
---

<section id="evelin" class="video">
  <div class="container video__head" data-reveal-group>
    <h2 class="video__title">
      Запознай се с Евелин - <span>капитанът на отбор INclusive</span>
    </h2>
    <p class="video__desc">
      С над 6 години опит и стотици реализирани сделки, Евелин Апостолов познава имотния
      бизнес от всички страни. Той стои зад развитието на INclusive в Пловдив и
      изграждането на екипа в София от нулата, а сега ти имаш възможността да се учиш и да
      работиш директно с него.
    </p>
  </div>

  <div class="video__stage-clip">
    <div class="video__stage">
      <img
        class="video__scene"
        src="/assets/images/video-scene.png"
        alt="Евелин Апостолов на екран в студио на INclusive"
        width="1470"
        height="1047"
        loading="lazy"
      />
      <button class="video__play" type="button" aria-label="Гледай видеото с Евелин" data-video-open>
        <span class="video__hotspot" aria-hidden="true"></span>
      </button>
      <!-- Video plays here — positioned exactly over the on-screen frame -->
      <div class="video__embed" data-video-embed hidden>
        <button class="video__close" type="button" aria-label="Затвори видеото" data-video-close>&times;</button>
        <div class="video__embed-inner" data-video-target></div>
      </div>
    </div>
  </div>
</section>

<style>
  .video {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.5em; /* 56px */
    padding-top: 5em; /* 80px */
    background-color: var(--color-gray-100);
    overflow: hidden;
  }

  .video__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4em;
  }

  .video__title {
    flex: 1 1 52%; /* ≈647px of 1248 container */
    min-width: 0;
    color: var(--color-gray-20);
    font-family: var(--font-heading);
    font-size: 3.25em; /* 52px */
    font-weight: 500;
    line-height: 1.15;
    text-transform: uppercase;
  }
  .video__title span { color: var(--color-gold-100); }

  .video__desc {
    flex: 1 1 40%; /* ≈498px of 1248 container */
    min-width: 0;
    color: var(--color-text-light);
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    font-weight: 300;
    line-height: 1.3;
  }

  /* Full-bleed projector scene */
  /* Clip wrapper: lets us zoom the stage on mobile without overflowing the text */
  .video__stage-clip {
    width: 100%;
    overflow: hidden;
  }
  .video__stage {
    position: relative;
    width: 100%;
    transform-origin: 50% 37%; /* zoom centered on the on-screen frame */
  }
  .video__scene {
    width: 100%;
    height: auto;
    display: block;
  }

  .video__play {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
  }

  /* Interactive play hotspot over the on-screen play button (≈50% / 36%) */
  .video__hotspot {
    position: absolute;
    left: 50%;
    top: 36%;
    width: 6em;
    height: 6em;
    transform: translate(-50%, -50%);
    border-radius: 12px;
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }
  .video__play:hover .video__hotspot,
  .video__play:focus-visible .video__hotspot {
    transform: translate(-50%, -50%) scale(1.08);
    box-shadow: 0 0 0 6px rgba(219, 189, 107, 0.35), 0 0 40px 8px rgba(219, 189, 107, 0.45);
  }

  /* Video plays inside the on-screen frame — matches the screen in the scene */
  .video__embed {
    position: absolute;
    left: 20.6%;
    top: 12.8%;
    width: 58.8%;
    height: 46.4%;
    background: #000;
    overflow: hidden;
    z-index: 2;
  }
  .video__embed-inner {
    width: 100%;
    height: 100%;
  }
  .video__embed-inner iframe,
  .video__embed-inner video {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    object-fit: cover;
  }
  .video__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: var(--color-gray-100);
    color: var(--color-text-light);
    font-family: var(--font-body);
    text-align: center;
    padding: 1em;
  }
  .video__close {
    position: absolute;
    top: 0;
    right: 0;
    z-index: 3;
    width: 2em;
    height: 2em;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25em;
    line-height: 1;
    color: #fff;
    background: rgba(0, 0, 0, 0.6);
    border: none;
    cursor: pointer;
  }
  .video__close:hover { background: rgba(0, 0, 0, 0.85); }

  /* ── Tablet ── */
  @media screen and (max-width: 991px) {
    .video__head { flex-direction: column; align-items: flex-start; gap: 1.5em; }
    .video__title { width: 100%; font-size: 2.75em; }
    .video__desc { width: 100%; }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .video { padding-top: 0; }
    .video__title { font-size: 2.1em; }
    .video__hotspot { width: 4em; height: 4em; }
    /* Zoom the whole stage (scene + player) toward the screen so the video is
       bigger; the clip wrapper hides the cropped edges. margin-top recenters it. */
    .video__stage { transform: scale(1.5); margin-top: 50px; }
  }
</style>

<script is:inline>
  (() => {
    const stage = document.querySelector('.video__stage');
    if (!stage) return;
    const playBtn = stage.querySelector('[data-video-open]');
    const embed = stage.querySelector('[data-video-embed]');
    const target = stage.querySelector('[data-video-target]');
    const closeBtn = stage.querySelector('[data-video-close]');

    // ▶ Евелин intro video — VidzFlow / YouTube / Vimeo / Google Drive link, or an .mp4 path:
    const VIDEO_SRC = 'https://app.vidzflow.com/v/uAl33DTKmm?dq=576&ap=false&muted=false&loop=false&ctp=true&bv=false&piv=false&playsinline=false&bc=%234E5FFD&controls=play-large%2Cplay%2Cprogress%2Ccurrent-time%2Cmute%2Cvolume%2Csettings%2Cfullscreen';

    const open = () => {
      const yt = VIDEO_SRC.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([\w-]+)/);
      const vimeo = VIDEO_SRC.match(/vimeo\.com\/(\d+)/);
      const drive = VIDEO_SRC.match(/drive\.google\.com\/file\/d\/([\w-]+)/);
      const vidzflow = VIDEO_SRC.includes('vidzflow.com');
      if (vidzflow) {
        // Force autoplay on (the user just clicked the play button).
        target.innerHTML = `<iframe src="${VIDEO_SRC.replace('ap=false', 'ap=true')}" title="Видео с Евелин" allow="autoplay; fullscreen" allowfullscreen></iframe>`;
      } else if (yt) {
        target.innerHTML = `<iframe src="https://www.youtube.com/embed/${yt[1]}?autoplay=1&rel=0" title="Видео с Евелин" allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>`;
      } else if (vimeo) {
        target.innerHTML = `<iframe src="https://player.vimeo.com/video/${vimeo[1]}?autoplay=1" title="Видео с Евелин" allow="autoplay; fullscreen" allowfullscreen></iframe>`;
      } else if (drive) {
        target.innerHTML = `<iframe src="https://drive.google.com/file/d/${drive[1]}/preview" title="Видео с Евелин" allow="autoplay; fullscreen" allowfullscreen></iframe>`;
      } else if (VIDEO_SRC) {
        target.innerHTML = `<video src="${VIDEO_SRC}" controls autoplay playsinline></video>`;
      } else {
        target.innerHTML = `<div class="video__placeholder">Видеото скоро ще бъде налично</div>`;
      }
      embed.hidden = false;
      playBtn.style.display = 'none';
    };

    const close = () => {
      target.innerHTML = '';
      embed.hidden = true;
      playBtn.style.display = '';
    };

    playBtn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
  })();
</script>
