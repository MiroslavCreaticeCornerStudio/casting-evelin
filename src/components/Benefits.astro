---
// Benefits — Какво печелиш? 3×2 grid. Figma node 2168:380
const icons = {
  chart:
    '<path d="M5 5v14h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 14l3-3 2.5 2.5L19 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
  chat:
    '<path d="M4 5h16v11H9l-4 3v-3H4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M8 9h8M8 12h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>',
  tv:
    '<path d="M9 5l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><rect x="3" y="8" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.6"/>',
  buildings:
    '<path d="M4 21V8l6-3v16M10 21h10V11l-6-2.5M13 12h2M13 15h2M13 18h2M6 12h1.5M6 15h1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
  user:
    '<rect x="4" y="4" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="10" r="2.4" stroke="currentColor" stroke-width="1.6"/><path d="M7.5 17a4.5 4.5 0 0 1 9 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>',
  briefcase:
    '<rect x="3" y="7.5" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8.5 7.5V6A1.5 1.5 0 0 1 10 4.5h4A1.5 1.5 0 0 1 15.5 6v1.5M3 13h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>',
};

const benefits = [
  { icon: 'chart', title: 'Кариера в недвижимите имоти', desc: 'Първа крачка към дългосрочно развитие в бранш с реални възможности за растеж и реализация.' },
  { icon: 'chat', title: 'Обучение на световно ниво', desc: 'Достъп до обучителна платформа, реални казуси, ролеви игри и тренинги с български и международни лектори.' },
  { icon: 'tv', title: 'Възможност за телевизионна изява', desc: 'Истинска възможност да застанеш до Евелин и отбор INclusive в новия сезон на „Борба до ключ“.' },
  { icon: 'buildings', title: 'Практически опит на терен', desc: 'Срещи с клиенти, огледи, разговори и ситуации, в които професията се учи най-бързо.' },
  { icon: 'user', title: 'Шанс да изградиш име', desc: 'Възможност да градиш доверие и разпознаваемост още от самото начало на кариерата си.' },
  { icon: 'briefcase', title: 'Работа в INclusive', desc: 'Подкрепа от експерти с 10+ години опит, ясни правила, човешко отношение и фокус върху развитието ти.' },
];
---

<section id="benefits" class="benefits">
  <div class="container">
    <div class="benefits__head">
      <span class="benefits__rule" aria-hidden="true"></span>
      <h2 class="benefits__title">Какво печелиш?</h2>
    </div>

    <ul class="benefits__grid" data-reveal-group>
      {benefits.map((b, i) => (
        <li class={`benefit ${i === 0 ? 'benefit--feature' : ''}`}>
          <svg class="benefit__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true" set:html={icons[b.icon]} />
          <h3 class="benefit__title">{b.title}</h3>
          <span class="benefit__divider" aria-hidden="true"></span>
          <p class="benefit__desc">{b.desc}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .benefits {
    background-color: var(--color-gray-100);
    padding-block: 5em 6em; /* 80 / 96 */
  }

  .benefits__head {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75em;
    margin-bottom: 3.5em;
    isolation: isolate;
  }
  /* Soft gold glow radiating from the rule */
  .benefits__head::before {
    content: '';
    position: absolute;
    top: -2em;
    left: 50%;
    width: 28em;
    height: 11em;
    transform: translateX(-50%);
    background: radial-gradient(
      ellipse 50% 50% at 50% 28%,
      rgba(219, 189, 107, 0.4) 0%,
      rgba(219, 189, 107, 0.13) 38%,
      transparent 70%
    );
    z-index: -1;
    pointer-events: none;
    animation: benefits-glow 4.5s ease-in-out infinite;
  }
  .benefits__rule {
    position: relative;
    width: 8.3125em; /* 133px */
    height: 4px;
    background: var(--color-gold-gradient);
    border-radius: 2px;
    box-shadow: 0 0 12px 3px rgba(219, 189, 107, 0.5);
  }
  @keyframes benefits-glow {
    0%, 100% { opacity: 0.78; }
    50% { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .benefits__head::before { animation: none; }
  }
  .benefits__title {
    color: var(--color-gray-20);
    font-family: var(--font-heading);
    font-size: 3.25em; /* 52px */
    font-weight: 500;
    line-height: 1.1;
    text-align: center;
    text-transform: uppercase;
  }

  .benefits__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid #525560;
    border-left: 1px solid #525560;
  }

  .benefit {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1em; /* 16px */
    padding: 2.5em 2.375em; /* 40 / 38 */
    border-right: 1px solid #525560;
    border-bottom: 1px solid #525560;
    isolation: isolate;
  }

  /* Featured (first) card — gold gradient wash + left accent */
  .benefit--feature::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(219, 189, 107, 0), rgba(219, 189, 107, 0.05) 33%, rgba(219, 189, 107, 0.2));
    opacity: 0.6;
    z-index: -1;
    pointer-events: none;
  }
  .benefit--feature {
    border-left: 3px solid transparent;
    border-image: var(--color-gold-gradient) 1;
  }

  .benefit__icon {
    width: 2.5em; /* 40px */
    height: 2.5em;
    color: var(--color-gold-80);
    margin-bottom: 0.625em;
  }

  .benefit__title {
    color: var(--color-text-light);
    font-family: var(--font-heading);
    font-size: 2em; /* 32px */
    font-weight: 500;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .benefit__divider {
    width: 1.5625em; /* 25px */
    height: 2px;
    background: var(--color-gold-gradient);
  }

  .benefit__desc {
    color: var(--color-gray-20);
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    font-weight: 300;
    line-height: 1.25;
  }

  /* ── Tablet ── */
  @media screen and (max-width: 991px) {
    .benefits__grid { grid-template-columns: repeat(2, 1fr); }
    .benefits__title { font-size: 2.75em; }
    .benefit__title { font-size: 1.75em; }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .benefits__grid { grid-template-columns: 1fr; }
    .benefits__title { font-size: 2.25em; }
  }
</style>
