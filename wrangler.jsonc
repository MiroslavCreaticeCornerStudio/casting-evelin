{
  // Cloudflare config for the Astro app deployed as a Worker (static pages +
  // the lead API / file routes) with an R2 bucket for uploaded CVs.
  // NOTE: "name" must match the Worker name shown in your Cloudflare dashboard.
  "name": "inclusive-casting",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist"
  },
  // R2 bucket for applicant CV uploads.
  // Create the bucket in Cloudflare and keep this binding name (UPLOADS).
  "r2_buckets": [
    {
      "binding": "UPLOADS",
      "bucket_name": "inclusive-uploads"
    }
  ]
}
