---
// "Who we're looking for" — Не търсим перфектно CV. Figma node 2168:444
const criteria = [
  'Имаш реална мотивация за работа и развитие, не просто желание за телевизионно участие',
  'Имаш готовност да участваш в процес, свързан с подбор, снимки и публична комуникация',
  'Можеш да бъдеш на разположение за следващи етапи от кастинга',
  'Чувстваш се комфортно пред камера или имаш желание да опиташ',
  'Искаш да се развиваш в имотния бизнес',
  'Имаш навършени 18 години',
  'Умееш да реагираш бързо в динамична среда',
];
---

<section id="who" class="who">
  <div class="container">
    <div class="who__head" data-reveal-group>
      <h2 class="who__title">
        Не търсим перфектно CV. <span>Търсим правилния човек.</span>
      </h2>
      <span class="who__rule" aria-hidden="true"></span>
      <p class="who__sub">
        Опитът в имотите не е задължителен, но правилната нагласа е. Тази възможност е за
        теб, ако:
      </p>
    </div>

    <div class="who__main">
      <div class="who__media" data-reveal>
        <img
          src="/assets/images/who-evelin.png"
          alt="Евелин Апостолов седнал, държащ табела „TOP“"
          width="542"
          height="535"
          loading="lazy"
        />
      </div>

      <ul class="who__grid" data-reveal-group>
        {criteria.map((c) => (
          <li class="who__cell">
            <span class="who__divider" aria-hidden="true"></span>
            <p>{c}</p>
          </li>
        ))}
        <li class="who__cell who__cta">
          <p class="who__cta-q">Комуникираш ясно и уверено?</p>
          <a href="#kandidatstvai" class="who__cta-link">
            Запиши се сега
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="20" height="20">
              <path d="M4 12h15M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .who {
    background-color: var(--color-gray-40);
    padding-block: 5em; /* 80px */
  }

  .who__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75em;
    text-align: center;
    margin-bottom: 3.5em;
  }
  .who__title {
    max-width: 900px;
    color: var(--color-gray-100);
    font-family: var(--font-heading);
    font-size: 3.25em; /* 52px */
    font-weight: 500;
    line-height: 1.15;
    text-transform: uppercase;
  }
  .who__title span { color: var(--color-gold-100); display: block; }
  .who__rule {
    width: 1.5625em; /* 25px */
    height: 2px;
    background: var(--color-gold-gradient);
    margin-top: 0.5em;
  }
  .who__sub {
    max-width: 660px;
    color: var(--color-gray-80);
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    font-weight: 700;
    line-height: 1.4;
  }

  .who__main {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2.5em;
  }

  .who__media {
    flex-shrink: 0;
    width: 33.875em; /* 542px */
  }
  .who__media img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .who__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    width: 42.625em; /* 682px */
    flex-shrink: 0;
  }

  .who__cell {
    display: flex;
    flex-direction: column;
    gap: 0.75em; /* 12px */
    padding: 1.5em; /* 24px */
    border-bottom: 1px solid rgba(82, 85, 96, 0.2);
    border-right: 1px solid rgba(82, 85, 96, 0.2);
  }
  .who__cell:nth-child(2n) { border-right: none; }
  .who__cell:nth-last-child(-n + 2) { border-bottom: none; }

  .who__divider {
    width: 1.5625em; /* 25px */
    height: 2px;
    background: var(--color-gold-gradient);
  }
  .who__cell p {
    color: var(--color-gray-80);
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    font-weight: 700;
    line-height: 1.3;
  }

  /* Gold CTA cell */
  .who__cta {
    background: var(--color-gold-80);
    justify-content: space-between;
    gap: 0.75em;
  }
  .who__cta-q {
    color: var(--color-gray-80) !important;
    font-weight: 600;
  }
  .who__cta-link {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5em;
    color: var(--color-gray-80);
    font-family: var(--font-body);
    font-size: 1.125em; /* 18px */
    font-weight: 700;
    transition: gap var(--transition-base);
  }
  .who__cta-link:hover { gap: 1em; }

  /* ── Tablet ── */
  @media screen and (max-width: 991px) {
    .who__title { font-size: 2.75em; }
    .who__main { flex-direction: column; align-items: center; gap: 2em; }
    .who__media { width: 100%; max-width: 33.875em; }
    .who__grid { width: 100%; }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .who { padding-block: 4em; }
    .who__title { font-size: 2.1em; }
    .who__grid { grid-template-columns: 1fr; }
    .who__cell { border-right: none; }
    .who__cell:nth-last-child(-n + 2) { border-bottom: 1px solid rgba(82, 85, 96, 0.2); }
    .who__cell:last-child { border-bottom: none; }
  }
</style>
