---
// Hero — "Стани звезден брокер в „Борба до ключ" 2 по NOVA"
// Figma node 2168:148
import novaLogo from '../../public/assets/images/nova-logo.png';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="container">
    <div class="hero__content">
      <span class="hero__eyebrow">
        <img src="/assets/images/hero-arrow.svg" alt="" width="8" height="8" class="hero__eyebrow-icon" />
        Кастингът е отворен
      </span>

      <h1 class="hero__title" id="hero-title">
        <span class="hero__title-line hero__title-line--gold">стани</span>
        <span class="hero__title-line hero__title-line--xl">Звезден брокер</span>
        <span class="hero__title-line hero__title-line--gold">в „Борба до ключ“ 2</span>
        <span class="hero__title-line hero__title-line--logo">
          <span class="hero__po">по</span>
          <img src={novaLogo.src} alt="NOVA" width="139" height="36" class="hero__nova" />
        </span>
      </h1>

      <p class="hero__desc">
        Идва нова битка. А за нея търсим човек, който има смелостта да влезе в света на
        INclusive, да научи имотния бизнес отвътре и да заеме своето място до Евелин
        Апостолов в отбора.
      </p>
      <p class="hero__desc hero__desc--alt">
        Спечели своето място като екранен партньор до Евелин.
      </p>

      <a href="#kandidatstvai" class="btn hero__cta">Кандидатствай сега</a>
    </div>
  </div>

  <!-- Shown ≤991px: image stacks below the text instead of sitting behind it -->
  <div class="hero__media" role="img" aria-label="Евелин Апостолов в студио на INclusive"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 46.375em; /* 742px */
    display: flex;
    align-items: center;
    padding-block: 7.375em 6.625em;
    background-color: var(--color-gray-100);
    /* Left-to-right dark overlay keeps the headline readable; the photo (Евелин + poster)
       stays visible on the right. Image aspect ≈ hero aspect, so cover crops minimally. */
    background-image:
      linear-gradient(
        90deg,
        rgba(33, 35, 43, 0.96) 0%,
        rgba(33, 35, 43, 0.85) 32%,
        rgba(33, 35, 43, 0) 60%
      ),
      url('/assets/images/hero-bg.jpg');
    background-size: cover, cover;
    background-position: center, center right;
    background-repeat: no-repeat, no-repeat;
    overflow: hidden;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 1em; /* 16px */
    align-items: flex-start;
    max-width: 35.5em; /* 568px */
  }

  /* Eyebrow badge */
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: 0.5em 1em; /* 8px 16px */
    border: 1px solid var(--color-gold-80);
    color: var(--color-text-light);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1em; /* 16px */
    line-height: 1.3;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .hero__eyebrow-icon {
    width: 0.5em;
    height: 0.5em;
    transform: rotate(-90deg) scaleY(-1);
  }

  /* Title */
  .hero__title {
    display: flex;
    flex-direction: column;
    gap: 0.25em;
    margin: 0;
    font-size: 1em; /* anchor: reset UA <h1> 2em so child em values resolve to design px */
    text-transform: uppercase;
    font-weight: 400;
    line-height: 1.2;
  }

  .hero__title-line--gold {
    color: var(--color-gold-80);
    font-size: 3em; /* 48px */
    font-weight: 500;
    white-space: nowrap;
  }

  .hero__title-line--xl {
    color: var(--color-text-light);
    font-size: 5.269em; /* 84.3px — matches Figma; real Le Havre is condensed so it fits one line */
    font-weight: 400;
    text-shadow: 4px 4px 6.8px rgba(255, 255, 255, 0.25);
    margin-block: -0.1em;
    white-space: nowrap;
  }

  .hero__title-line--logo {
    display: inline-flex;
    align-items: center;
    gap: 0.444em; /* 16px relative to 36px */
    font-size: 2.25em; /* 36px */
    margin-top: 0.2em;
  }

  .hero__po {
    color: var(--color-text-white);
    font-weight: 500;
    text-shadow: 4px 4px 6.8px rgba(255, 255, 255, 0.25);
  }

  .hero__nova {
    width: 3.86em; /* 139px / 36 */
    height: auto;
    display: inline-block;
  }

  /* Description */
  .hero__desc {
    color: var(--color-text-light);
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    line-height: 1.5;
    max-width: 35.5em;
  }

  /* Short alternate description — shown only ≤991px */
  .hero__desc--alt {
    display: none;
  }

  .hero__cta {
    margin-top: 0;
  }

  /* Stacked image block — desktop hides it (image is the section background instead) */
  .hero__media {
    display: none;
  }

  /* ── Tablet & below (≤991px): text on solid dark, image stacked below ── */
  @media screen and (max-width: 991px) {
    .hero {
      display: block;
      min-height: 0;
      padding-block: 2em 0em;
      background-image: none; /* text sits on solid dark, not over the photo */
      background-color: var(--color-gray-100);
    }
    .hero__content {
      max-width: 100%;
    }
    .hero__title-line--xl {
      font-size: 4.2em;
    }
    /* Swap to the short, bold description */
    .hero__desc {
      display: none;
    }
    .hero__desc--alt {
      display: block;
      font-weight: 700;
    }
    .hero__media {
      display: block;
      min-height: 420px;
      background-image: url('/assets/images/hero-bg.jpg');
      background-size: cover;
      background-position: 100% 50%;
      background-repeat: no-repeat;
    }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .hero__content {
      gap: 1em;
      max-width: 100%;
      margin-bottom: 2em;
    }
    .hero__title-line--gold {
      font-size: 2.25em;
      white-space: normal;
    }
    .hero__title-line--xl {
      font-size: 3.2em;
      white-space: normal;
    }
    .hero__title-line--logo {
      font-size: 1.75em;
    }
    .hero__desc {
      font-size: 1.0625em;
    }
  }

  @media screen and (max-width: 479px) {
    .hero__title-line--xl {
      font-size: 2.6em;
    }
  }
</style>
