---
// Process — От кандидатура до място в отбора. Figma node 2168:480
const steps = [
  {
    n: '1',
    title: 'Кандидатствай онлайн',
    desc: 'Попълни кратката форма на тази страница и ни изпрати своята кандидатура до началото на август 2026 г.',
  },
  {
    n: '2',
    title: 'Ела на кастинг в София',
    desc: 'Избраните кандидати ще получат покана за кастинг в София. Там ще се запознаем на живо, ще поговорим повече за възможността и ще ни разкажеш малко повече за себе си.',
  },
  {
    n: '3',
    title: 'Стани част от екипа',
    desc: 'След кастинга един човек ще получи възможност да стане част от INclusive, където започва истинското приключение.',
  },
];
---

<section id="process" class="process">
  <img src="/assets/images/film-strip.svg" alt="" class="process__film" aria-hidden="true" />

  <div class="container">
    <div class="process__head">
      <span class="process__rule" aria-hidden="true"></span>
      <h2 class="process__title">От кандидатура до място в отбора</h2>
    </div>

    <ol class="process__steps" data-reveal-group>
      {steps.map((s, i) => (
        <>
          <li class="step">
            <span class="step__num" aria-hidden="true">{s.n}</span>
            <h3 class="step__title">{s.title}</h3>
            <p class="step__desc">{s.desc}</p>
          </li>
          {i < steps.length - 1 && <span class="process__sep" aria-hidden="true"></span>}
        </>
      ))}
    </ol>
  </div>
</section>

<style>
  .process {
    position: relative;
    background-color: var(--color-gray-100);
    padding-block: 4.8125em 8.75em; /* 77 / 140 */
    overflow: hidden;
    isolation: isolate;
  }

  .process__film {
    position: absolute;
    top: 63%;
    left: 50%;
    width: 136%;
    height: 55%;
    max-width: none;
    transform: translate(-50%, -50%);
    opacity: 0.6;
    z-index: -1;
    pointer-events: none;
  }

  .process__head {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3em; /* 48px */
    margin-bottom: 5.875em; /* 94px */
    isolation: isolate;
  }
  /* Soft gold glow radiating from the rule */
  .process__head::before {
    content: '';
    position: absolute;
    top: -2em;
    left: 50%;
    width: 28em;
    height: 11em;
    transform: translateX(-50%);
    background: radial-gradient(
      ellipse 50% 50% at 50% 28%,
      rgba(219, 189, 107, 0.4) 0%,
      rgba(219, 189, 107, 0.13) 38%,
      transparent 70%
    );
    z-index: -1;
    pointer-events: none;
    animation: process-glow 4.5s ease-in-out infinite;
  }
  .process__rule {
    position: relative;
    width: 8.3125em; /* 133px */
    height: 4px;
    background: var(--color-gold-gradient);
    border-radius: 2px;
    box-shadow: 0 0 12px 3px rgba(219, 189, 107, 0.5);
  }
  @keyframes process-glow {
    0%, 100% { opacity: 0.78; }
    50% { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .process__head::before { animation: none; }
  }
  .process__title {
    max-width: 620px;
    color: var(--color-gray-20);
    font-family: var(--font-heading);
    font-size: 3.25em; /* 52px */
    font-weight: 500;
    line-height: 1.15;
    text-align: center;
    text-transform: uppercase;
  }

  .process__steps {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: 4em; /* 64px */
  }

  .step {
    flex: 1 0 0;
    display: flex;
    flex-direction: column;
    gap: 1.5em; /* 24px */
  }
  .step__num {
    font-family: var(--font-body);
    font-size: 7.5em; /* 120px */
    font-weight: 800;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px var(--color-gold-100);
    text-stroke: 1.5px var(--color-gold-100);
  }
  .step__title {
    color: var(--color-text-light);
    font-family: var(--font-heading);
    font-size: 1.5em; /* 24px */
    font-weight: 500;
    text-transform: uppercase;
    margin-bottom: -1em; /* keep title->desc gap = 8px */
  }
  .step__desc {
    color: var(--color-text-light);
    font-family: var(--font-body);
    font-size: 1.125em; /* 18px */
    font-weight: 300;
    line-height: 1.45;
  }

  .process__sep {
    width: 1px;
    align-self: center;
    height: 16.875em; /* 270px */
    background: linear-gradient(180deg, transparent, rgba(219, 189, 107, 0.35) 50%, transparent);
    flex-shrink: 0;
  }

  /* ── Tablet ── */
  @media screen and (max-width: 991px) {
    .process__title { font-size: 2.75em; }
    .process__steps { gap: 2.5em; }
    .step__num { font-size: 6em; }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .process { padding-block: 4em; }
    .process__title { font-size: 2.1em; }
    .process__steps { flex-direction: column; align-items: stretch; gap: 2em; }
    .process__sep { width: 100%; height: 1px; background: linear-gradient(90deg, transparent, rgba(219, 189, 107, 0.35) 50%, transparent); }
    .step__title { margin-bottom: -0.6em; }
  }
</style>
